# ─────────────────────────────────────────────
# AutoTrack CRM — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── META / FACEBOOK ──────────────────────────
# From Meta Business > App Settings > Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# From Meta Business > Webhooks > Verify Token (you choose this string)
META_WEBHOOK_VERIFY_TOKEN=autotrack_trupti_2026

# From Meta Business > App Settings > Access Tokens (Page Access Token)
META_PAGE_ACCESS_TOKEN=your_page_access_token

# Meta Lead Ad Form IDs (from each campaign's form)
# Add all your form IDs comma-separated
META_FORM_IDS=form_id_tata_pv,form_id_tata_cv,form_id_toyota

# ── FIREBASE ──────────────────────────────────
# From Firebase Console > Project Settings > Service Account > Generate Key
FIREBASE_PROJECT_ID=autotrack-trupti
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@autotrack-trupti.iam.gserviceaccount.com

# Firebase database URL (Realtime DB, if used)
FIREBASE_DATABASE_URL=https://autotrack-trupti-default-rtdb.firebaseio.com

# ── WHATSAPP (AiSensy / Gallabox) ─────────────
# From AiSensy Dashboard > API Keys
WHATSAPP_API_KEY=your_aisensy_api_key
WHATSAPP_CAMPAIGN_NAME_NEW_LEAD=autotrack_new_lead
WHATSAPP_SENDER_ID=your_whatsapp_number

# ── SERVER ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── BRAND ROUTING ─────────────────────────────
# Showroom branch codes for routing logic
BRANCH_TATA_PV=TRUPTI_MOTORS
BRANCH_TATA_CV=TRUPTI_AUTOMOTIVES
BRANCH_TOYOTA=TRUPTI_TOYOTA
